# CMake configuration file for thrift
#
# This provides the FBThrift::thrift target, which you can depend on by adding it
# to your target_link_libraries().
#
# It also defines the following variables, although using these directly is not
# necessary if you use the FBThrift::thrift target instead.
#  FBTHRIFT_INCLUDE_DIR
#  FBTHRIFT_LIBRARIES

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set_and_check(FBTHRIFT_INCLUDE_DIR "@PACKAGE_INCLUDE_INSTALL_DIR@")

# Include the fbthrift-targets.cmake file, which is generated from our CMake rules
if (NOT TARGET FBThrift::thrift)
  include("${THRIFT_CMAKE_DIR}/fbthrift-targets.cmake")
endif()

set(FBTHRIFT_LIBRARIES FBThrift::thrift)

find_dependency(folly)
