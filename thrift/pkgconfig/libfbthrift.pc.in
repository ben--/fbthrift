prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=@CMAKE_INSTALL_PREFIX@
libdir=${exec_prefix}/@LIB_INSTALL_DIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: libfbthrift
Description: Facebook fork of Apache Thrift
Version: @PACKAGE_VERSION@
Cflags: -I${includedir} @FBTHRIFT_PKGCONFIG_CFLAGS@
Libs: -L${libdir} -lfbthrift
Libs.private: @FBTHRIFT_PKGCONFIG_PRIVATE_LIBS@
